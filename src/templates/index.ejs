<!-- Hero Section -->
<div class="hero-section">
  <div class="row align-items-center">
    <div class="col-md-8">
      <h1 class="hero-title">发现优质软件与资源</h1>
      <p class="text-muted mb-3">专注绿色纯净资源，免费、安全、无套路</p>
    </div>
    <div class="col-md-4">
      <div class="hero-stats justify-content-end">
        <div class="hero-stat">
          <span class="number"><%= posts.length %></span>
          <span class="label">资源总量</span>
        </div>
        <div class="hero-stat">
          <span class="number"><%= categories.length %></span>
          <span class="label">分类</span>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Featured Posts Carousel -->
<% var featured = posts.filter(function(p) { return p.is_featured; }); %>
<% if (featured.length > 0) { %>
<div id="featuredCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
  <div class="carousel-inner">
    <% featured.forEach(function(post, idx) { %>
    <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
      <div class="featured-card">
        <div class="featured-bg" style="background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(124,58,237,0.15));"></div>
        <div class="featured-overlay">
          <div class="featured-cat"><%= post.category_name || '未分类' %></div>
          <a href="/post/<%= post.slug %>" class="featured-title"><%= post.title %></a>
          <small class="text-muted"><%= post.created_at ? new Date(post.created_at).toLocaleDateString('zh-CN') : '' %></small>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
  <button class="carousel-control-prev" type="button" data-bs-target="#featuredCarousel" data-bs-slide="prev">
    <span class="carousel-control-prev-icon"></span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#featuredCarousel" data-bs-slide="next">
    <span class="carousel-control-next-icon"></span>
  </button>
</div>
<% } %>

<!-- Categories Grid -->
<div class="row g-3 mb-4">
  <% categories.forEach(function(cat) { %>
  <div class="col-4 col-md-2">
    <a href="/category/<%= cat.slug %>" class="cat-card">
      <div class="cat-icon"><i class="fa <%= cat.icon %>"></i></div>
      <div class="cat-name"><%= cat.name %></div>
      <div class="cat-count"><%= posts.filter(function(p) { return p.category_id === cat.id; }).length %> 篇</div>
    </a>
  </div>
  <% }); %>
</div>

<!-- Latest Posts -->
<div class="section-header">
  <h3>最新资源</h3>
</div>

<div class="row g-3">
  <% if (posts.length > 0) { %>
    <% posts.forEach(function(post) { %>
    <div class="col-6 col-md-4 col-lg-3">
      <div class="card h-100">
        <div class="card-img-top d-flex align-items-center justify-content-center" style="background: linear-gradient(135deg, rgba(0,212,255,0.1), rgba(124,58,237,0.1));">
          <i class="fa fa-download" style="font-size: 2.5rem; color: var(--accent); opacity: 0.5;"></i>
        </div>
        <div class="card-body">
          <h5 class="card-title"><a href="/post/<%= post.slug %>"><%= post.title %></a></h5>
          <p class="card-text"><%= post.summary || '暂无摘要' %></p>
        </div>
        <div class="card-footer">
          <span><i class="fa fa-folder-o"></i> <%= post.category_name || '未分类' %></span>
          <span class="float-end"><i class="fa fa-eye"></i> <%= post.view_count %></span>
        </div>
      </div>
    </div>
    <% }); %>
  <% } else { %>
    <div class="col-12">
      <div class="empty-state">
        <div class="empty-icon"><i class="fa fa-inbox"></i></div>
        <p>暂无内容，敬请期待</p>
      </div>
    </div>
  <% } %>
</div>
